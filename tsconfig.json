{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "lib/typescript",
    "rootDir": ".",
    "jsx": "react-native",
    "types": ["react", "react-native"]
  },
  "include": ["src/**/*.ts"]
}

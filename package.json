{
  "name": "pretext-rn",
  "version": "0.1.0-alpha",
  "description": "Synchronous text measurement for React Native using JSI",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.ts",
  "repository": {
    "type": "git",
    "url": "https://example.com/pretext-rn.git"
  },
  "files": [
    "src/",
    "android/src/",
    "android/build.gradle",
    "ios/",
    "cpp/",
    "pretext-rn.podspec",
    "*.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "android:legacy:parity": "bash scripts/android-legacy-parity.sh",
    "ios:legacy:parity": "bash scripts/ios-legacy-parity.sh"
  },
  "keywords": [
    "react-native",
    "jsi",
    "text-measurement",
    "text-height",
    "old-architecture"
  ],
  "author": "aku47z",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
